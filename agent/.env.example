# Device Agent – copy to .env and fill in.
# Get your API key from the app: Settings → Connect real devices.

API_BASE_URL=https://your-app.example.com
DEVICE_AGENT_API_KEY=your_device_agent_api_key_here

# Optional: report interval (seconds). Default 30.
# DEVICE_AGENT_INTERVAL=30
# Optional: timeout for checking each device (seconds). Default 5.
# DEVICE_AGENT_TIMEOUT=5
# Optional: config directory (default: same folder as this script).
# DEVICE_AGENT_CONFIG_DIR=/path/to/config

# Network watchdog (DNS change + unknown device detection). Runs alongside heartbeats.
ENABLE_NETWORK_WATCHDOG=true
WATCHDOG_INTERVAL=60
# Your router and/or preferred DNS (comma-separated). Must match your actual network (e.g. 192.168.0.1 for 192.168.0.x).
EXPECTED_DNS=192.168.0.1,8.8.8.8
ENABLE_DNS_CHECK=true
ENABLE_UNKNOWN_DEVICE_CHECK=true
