# =============================================================================
# Pro-Alert – copy to .env and fill in. For production, set these
# in your host (Railway, Render, etc.) or in .env on your server.
# =============================================================================

## Core (required for production)
MONGO_URI=mongodb://localhost:27017/iot_security
PORT=8000
JWT_SECRET=change-me-in-production

## Production URL (required when live – for email links and CORS)
# Canonical site: https://www.pro-alert.co.uk (set the same in Railway Variables + mobile app.json extra.apiUrl)
APP_BASE_URL=http://localhost:8000
APP_ENV=local
# MAINTENANCE_MODE=true  # On Railway: 503 for site + API except GET /api/health and /api/ready (local dev: leave unset)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

## Email (required for signup flow – verification link is sent on every signup when SMTP is set)
## Signup never returns a session; users must verify then log in before dashboard.
# Gmail: use App Password (2FA required). Or use SendGrid.
SENDGRID_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

## SMS / Voice / WhatsApp (optional – Twilio)
## Set these to receive phone calls, SMS, and WhatsApp when devices go offline.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# For WhatsApp Sandbox (trial): use the sandbox sender number. Get it from Twilio Console → Messaging → Try it out → Send a WhatsApp message (e.g. +14155238886).
TWILIO_WHATSAPP_NUMBER=
# SMS is enabled by default when Twilio is configured. Set SMS_ENABLED=false to disable.
SMS_ENABLED=true

## Payments (Stripe – monthly subscriptions via Checkout)
# Dashboard: Products → monthly prices in GBP; copy price_... IDs.
# Webhook URL: https://YOUR_DOMAIN/api/payments/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# Billing → Customer portal: activate so /api/payments/customer-portal works.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

## Security (production – recommended)
# Stable CSRF secret (32+ chars); required in production by scripts/security_gate.py
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# CSRF_SECRET=
# FORCE_HTTPS=true
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# ENABLE_HSTS=true
# Pro-Alert on Railway (www + bare domain for direct/API hits + deploy healthcheck):
# APP_BASE_URL=https://www.pro-alert.co.uk
# CORS_ORIGINS=https://www.pro-alert.co.uk,https://pro-alert.co.uk
# ALLOWED_HOSTS=www.pro-alert.co.uk,pro-alert.co.uk,healthcheck.railway.app
#
# Email verification on signup (recommended for production)
# - When true: signup does NOT return a JWT/cookie; user must open verify link then log in.
# - Verification email is sent when SMTP_USER, SMTP_PASSWORD, FROM_EMAIL are set (or on every signup in production).
# REQUIRE_EMAIL_VERIFICATION=true
# EMAIL_VERIFICATION_ENABLED=true
# REQUIRE_EMAIL_VERIFICATION / EMAIL_VERIFICATION_ENABLED are no longer required –
# verify-before-dashboard is always enforced. SMTP must be set so users receive the link.
# Platform network monitor (IP change, DNS hostname checks). In cloud, cannot scan private LANs – use agent watchdog instead.
ENABLE_NETWORK_MONITORING=true