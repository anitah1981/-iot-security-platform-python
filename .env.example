# =============================================================================
# IoT Security Platform – copy to .env and fill in. For production, set these
# in your host (Railway, Render, etc.) or in .env on your server.
# =============================================================================

## Core (required for production)
MONGO_URI=mongodb://localhost:27017/iot_security
PORT=8000
JWT_SECRET=change-me-in-production

## Production URL (required when live – for email links and CORS)
# Set to your live URL, e.g. https://your-app.up.railway.app
APP_BASE_URL=http://localhost:8000
APP_ENV=local
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

## Email (optional – for signup, password reset, alerts)
# Gmail: use App Password (2FA required). Or use SendGrid.
SENDGRID_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

## SMS / Voice (optional – Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

## Payments (optional – Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

## Security (optional – production)
# FORCE_HTTPS=true
# ALLOWED_HOSTS=yourdomain.com
# ENABLE_NETWORK_MONITORING=false
